<?xml version="1.0" encoding="UTF-8"?>
<mxfile host="app.diagrams.net">
  <diagram name="UML POS">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1"
      connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1100"
      pageHeight="850" math="0" shadow="0">

      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- Usuario -->
        <mxCell id="Usuario" value="Usuario
-------------------------
- id
- nombre
- contraseña
-------------------------
+ login()
+ logout()" style="shape=rectangle" vertex="1" parent="1">
          <mxGeometry x="100" y="100" width="180" height="140" as="geometry"/>
        </mxCell>

        <!-- Administrador -->
        <mxCell id="Administrador" value="Administrador
-------------------------
+ agregarProducto()
+ eliminarProducto()
+ generarReporte()" style="shape=rectangle" vertex="1" parent="1">
          <mxGeometry x="50" y="300" width="180" height="140" as="geometry"/>
        </mxCell>

        <!-- Cajero -->
        <mxCell id="Cajero" value="Cajero
-------------------------
+ registrarVenta()
+ generarTicket()" style="shape=rectangle" vertex="1" parent="1">
          <mxGeometry x="250" y="300" width="180" height="140" as="geometry"/>
        </mxCell>

        <!-- Producto -->
        <mxCell id="Producto" value="Producto
-------------------------
- id
- nombre
- precio
- stock
-------------------------
+ actualizarStock()" style="shape=rectangle" vertex="1" parent="1">
          <mxGeometry x="600" y="100" width="180" height="160" as="geometry"/>
        </mxCell>

        <!-- Venta -->
        <mxCell id="Venta" value="Venta
-------------------------
- id
- fecha
- total
-------------------------
+ calcularTotal()" style="shape=rectangle" vertex="1" parent="1">
          <mxGeometry x="450" y="300" width="180" height="160" as="geometry"/>
        </mxCell>

        <!-- Detalle Venta -->
        <mxCell id="DetalleVenta" value="DetalleVenta
-------------------------
- cantidad
- subtotal
-------------------------
+ calcularSubtotal()" style="shape=rectangle" vertex="1" parent="1">
          <mxGeometry x="700" y="300" width="180" height="160" as="geometry"/>
        </mxCell>

        <!-- Metodo Pago -->
        <mxCell id="MetodoPago" value="MetodoPago
-------------------------
- tipo
-------------------------
+ procesarPago()" style="shape=rectangle" vertex="1" parent="1">
          <mxGeometry x="450" y="500" width="180" height="140" as="geometry"/>
        </mxCell>

        <!-- Ticket -->
        <mxCell id="Ticket" value="Ticket
-------------------------
- numero
-------------------------
+ imprimir()" style="shape=rectangle" vertex="1" parent="1">
          <mxGeometry x="650" y="500" width="180" height="140" as="geometry"/>
        </mxCell>

        <!-- Herencia -->
        <mxCell id="Herencia1" style="endArrow=block" edge="1" parent="1"
         source="Administrador" target="Usuario">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="Herencia2" style="endArrow=block" edge="1" parent="1"
         source="Cajero" target="Usuario">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Asociaciones -->
        <mxCell id="Relacion1" style="endArrow=open" edge="1" parent="1"
         source="Venta" target="DetalleVenta">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="Relacion2" style="endArrow=open" edge="1" parent="1"
         source="DetalleVenta" target="Producto">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="Relacion3" style="endArrow=open" edge="1" parent="1"
         source="Venta" target="MetodoPago">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="Relacion4" style="endArrow=open" edge="1" parent="1"
         source="Venta" target="Ticket">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>